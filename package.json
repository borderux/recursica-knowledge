{
  "name": "@recursica/knowledge",
  "description": "Recursica design system central knowledge, documentation, and agent instructions",
  "version": "0.2.0",
  "bin": {
    "recursica-knowledge": "./bin/init.js"
  },
  "private": false,
  "workspaces": [
    ".",
    "skills/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/borderux/recursica-knowledge#readme",
  "bugs": {
    "url": "https://github.com/borderux/recursica-knowledge/issues"
  },
  "author": "hi@borderux.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borderux/recursica-knowledge.git"
  },
  "files": [
    "bin",
    "components",
    "skills",
    "docs",
    "llms.txt",
    "AGENT.md",
    "README.md",
    "CONTRIBUTING.md",
    "SETUP.md",
    ".claude-plugin",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-skills.js",
    "postinstall": "node bin/init.js",
    "version": "changeset version && node scripts/sync-skill-versions.js",
    "release": "changeset publish",
    "prepare": "node .husky/install.mjs",
    "format": "prettier --write \"**/*.{json,md,yml,yaml}\""
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "3.5.3"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
